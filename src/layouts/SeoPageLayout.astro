---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Services from '../components/Services.astro';
import Location from '../components/Location.astro';
import FAQItem from '../components/FAQItem.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
	title: string;
	description: string;
	h1: string;
	landmark: string;
	distance: string;
}

const { title, description, h1, landmark, distance } = Astro.props;

const miniFaqs = [
	{ question: 'Do I need an appointment?', answer: 'Walk-ins are welcome, and you can also message us on WhatsApp before arriving.' },
	{ question: `How far is the clinic from ${landmark}?`, answer: `Clinic Mediviron Jalan Imbi is ${distance} from ${landmark}.` },
	{ question: 'What services are available?', answer: 'General practice, ECG, and ultrasound services are available on-site.' },
];

const nearbyLinks = [
	{ href: '/near-trx', label: 'Near TRX' },
	{ href: '/near-pavilion', label: 'Near Pavilion' },
	{ href: '/near-klcc', label: 'Near KLCC' },
	{ href: '/near-bukit-bintang', label: 'Near Bukit Bintang' },
	{ href: '/near-berjaya-times-square', label: 'Near Berjaya Times Square' },
	{ href: '/near-jalan-imbi', label: 'Jalan Imbi' },
];
---

<Layout title={title} description={description}>
	<Header />
	<main>
		<section class="relative overflow-hidden py-16">
			<div class="absolute inset-0 bg-[linear-gradient(135deg,_#f0fdfa,_#ccfbf1)]"></div>
			<div class="section-shell relative">
				<div class="mx-auto max-w-3xl text-center">
					<p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Nearby Clinic</p>
					<h1 class="mt-3 text-3xl font-bold text-[var(--color-text)] sm:text-5xl">{h1}</h1>
					<p class="mt-5 text-lg leading-8 text-[var(--color-muted)]">
						Clinic Mediviron Jalan Imbi is a trusted family clinic just {distance} from {landmark}, making it convenient for appointments, walk-ins, and quick check-ins during a busy KL day.
					</p>
					<a
						href="https://wa.me/60XXXXXXXXXX"
						target="_blank"
						rel="noopener noreferrer"
						class="cta-primary mt-8 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400 focus-visible:ring-offset-2"
					>
						Book via WhatsApp
					</a>
				</div>
			</div>
		</section>

		<Services />
		<Location />

		<section class="bg-white py-16">
			<div class="section-shell">
				<div class="mx-auto max-w-2xl">
					<h2 class="text-center text-3xl font-bold text-[var(--color-text)]">Common Questions</h2>
					<div class="mt-8 flex flex-col gap-4">
						{miniFaqs.map((faq, index) => <FAQItem question={faq.question} answer={faq.answer} id={`seo-${index}`} />)}
					</div>
				</div>
			</div>
		</section>

		<section class="py-10">
			<div class="section-shell">
				<div class="mx-auto max-w-3xl text-center">
					<p class="text-sm text-[var(--color-muted)]">Looking for a clinic near another nearby KL landmark?</p>
					<div class="mt-5 flex flex-wrap justify-center gap-3">
						{
							nearbyLinks.map((link) => (
								<a href={link.href} class="rounded-full border border-teal-300 px-4 py-2 text-sm font-semibold text-teal-700 transition-colors duration-200 hover:bg-teal-50">
									{link.label}
								</a>
							))
						}
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
	<WhatsAppButton />
</Layout>
