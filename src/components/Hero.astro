---
import { CLINIC, whatsappUrl } from '../config/clinic';
---
<section class="relative overflow-hidden">
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(20,184,166,0.18),transparent_38%),linear-gradient(135deg,#f0fdfa_0%,#ccfbf1_48%,#99f6e4_100%)]"></div>
	<div class="section-shell relative grid min-h-[calc(100vh-4rem)] items-center gap-12 py-20 md:grid-cols-[1.1fr_0.9fr]">
		<div>
			<span class="mb-5 inline-flex rounded-full bg-white/70 px-4 py-1.5 text-sm font-semibold text-teal-700 ring-1 ring-teal-200">
				Walk-ins Welcome
			</span>
			<h1 class="max-w-xl text-4xl font-bold leading-tight text-text sm:text-5xl lg:text-6xl">
				{CLINIC.tagline}
			</h1>
			<p class="mt-5 max-w-2xl text-lg leading-8 text-muted">
				Caring for you and your family with modern facilities, experienced doctors, and a friendly team right in the heart of Kuala Lumpur.
			</p>
			<div class="mt-8 flex flex-col gap-4 sm:flex-row">
				<a
					href={whatsappUrl()}
					target="_blank"
					rel="noopener noreferrer"
					class="cta-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400 focus-visible:ring-offset-2"
				>
					Book Appointment via WhatsApp
				</a>
				<a href="#services" class="cta-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2">
					Our Services
				</a>
			</div>
			<div class="mt-8 flex flex-wrap gap-3 text-sm text-muted">
				<span class="rounded-full bg-white/80 px-4 py-2 ring-1 ring-teal-100">General Practice</span>
				<span class="rounded-full bg-white/80 px-4 py-2 ring-1 ring-teal-100">ECG On-Site</span>
				<span class="rounded-full bg-white/80 px-4 py-2 ring-1 ring-teal-100">Ultrasound Available</span>
			</div>
		</div>

		<div class="hidden md:block">
			<div class="rounded-4xl bg-white/85 p-6 shadow-(--shadow-card) ring-1 ring-teal-100 backdrop-blur">
				<div class="rounded-3xl border-2 border-dashed border-teal-300 bg-[linear-gradient(180deg,rgba(240,253,250,0.9),white)] p-10 text-center text-muted">
					<div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-2xl bg-teal-100 text-teal-700">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
						</svg>
					</div>
					<p class="font-heading text-xl font-semibold text-text">Photo Placeholder</p>
					<p class="mt-3 text-sm leading-7">
						Replace this block with a clinic front desk, doctor portrait, or interior image to strengthen first-visit trust.
					</p>
				</div>
			</div>
		</div>
	</div>
	<div class="pointer-events-none absolute bottom-8 left-1/2 hidden -translate-x-1/2 animate-bounce text-teal-700 md:block" aria-hidden="true">
		<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
		</svg>
	</div>
</section>
