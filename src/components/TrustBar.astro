---
const trustItems = [
	{
		label: 'Friendly & Experienced Doctors',
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />`,
	},
	{
		label: 'ECG & Ultrasound On-Site',
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 12h4l3-9 4 18 3-9h4" />`,
	},
	{
		label: 'Walk-ins Welcome',
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />`,
	},
];
---

<section class="bg-teal-700 text-white">
	<div class="section-shell py-4">
		<div class="flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-10">
			{
				trustItems.map((item) => (
					<div class="flex items-center gap-3 text-sm font-semibold tracking-wide">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-teal-100" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" set:html={item.icon} />
						<span>{item.label}</span>
					</div>
				))
			}
		</div>
	</div>
</section>
