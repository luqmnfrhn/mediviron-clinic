---
const highlights = [
	'Walk-in and appointment-based consultations',
	'On-site ECG and ultrasound diagnostics',
	'Panel and corporate insurance accepted',
	'Same-day medical certificates after consultation',
	'Convenient location near TRX, Pavilion, and Bukit Bintang',
];
---

<section class="py-20">
	<div class="section-shell grid items-center gap-12 md:grid-cols-[1.05fr_0.95fr]">
		<div>
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Why Choose Us</p>
			<h2 class="mt-3 text-3xl font-bold text-text sm:text-4xl">Warm care with modern clinic support</h2>
			<p class="mt-5 text-lg leading-8 text-muted">
				Clinic Mediviron Jalan Imbi is designed to feel approachable from the moment a patient arrives. We combine trusted community GP care with convenient on-site diagnostics, helping patients and working professionals get answers without extra hassle.
			</p>
			<ul class="mt-8 space-y-4">
				{
					highlights.map((point) => (
						<li class="flex items-start gap-3 text-muted">
							<svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 shrink-0 text-teal-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path>
							</svg>
							<span>{point}</span>
						</li>
					))
				}
			</ul>
		</div>

		<div class="rounded-4xl bg-white p-5 shadow-(--shadow-card) ring-1 ring-teal-100">
			<div class="flex h-88 items-center justify-center rounded-3xl border-2 border-dashed border-teal-300 bg-[linear-gradient(180deg,#ffffff,#f0fdfa)] p-8 text-center text-muted">
				<div>
					<p class="font-heading text-2xl font-semibold text-text">Interior / Team Photo</p>
					<p class="mt-4 text-sm leading-7">
						Replace with a warm clinic interior, doctor team image, or consultation setting to reinforce trust and professionalism.
					</p>
				</div>
			</div>
		</div>
	</div>
</section>
