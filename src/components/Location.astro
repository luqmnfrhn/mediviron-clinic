---
import { CLINIC, whatsappUrl } from '../config/clinic';
---
<section id="location" class="py-20">
	<div class="section-shell">
		<div class="mx-auto max-w-2xl text-center">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-teal-700">Location & Contact</p>
			<h2 class="mt-3 text-3xl font-bold text-text sm:text-4xl">Find us in the heart of KL</h2>
			<p class="mt-4 text-lg text-muted">
				Close to TRX, Pavilion, Bukit Bintang, and Jalan Imbi landmarks for quick access before or after work.
			</p>
		</div>

		<div class="mt-12 grid gap-8 md:grid-cols-[1.05fr_0.95fr]">
			<div class="flex min-h-80 items-center justify-center rounded-[1.75rem] border border-teal-100 bg-white p-6 text-center text-sm leading-7 text-muted shadow-(--shadow-card)">
				<div>
					<p class="font-heading text-2xl font-semibold text-text">Google Maps Clinic </p>
					<p class="mt-3">
						<iframe
						src={CLINIC.mapsEmbedUrl}
						width="100%"
						height="100%"
						style="border:0;"
						allowfullscreen
						loading="lazy"
						referrerpolicy="no-referrer-when-downgrade"
						title="Klinic Mediviron Jalan Imbi location on Google Maps"
						></iframe>
					</p>
				</div>
			</div>

			<div class="rounded-[1.75rem] border border-teal-100 bg-white p-8 shadow-(--shadow-card)">
				<h3 class="text-2xl font-semibold text-text">{CLINIC.name}</h3>
				<p class="mt-4 text-base leading-7 text-muted">
					{CLINIC.address}
					<br />
					{CLINIC.fullAddress}
				</p>

				<div class="mt-6">
					<p class="text-sm font-semibold uppercase tracking-[0.16em] text-teal-700">Operating Hours</p>
					<p class="mt-3 text-base leading-7 text-muted">
						{CLINIC.hours.weekdays}
						<br />
						{CLINIC.hours.weekend_public}
					</p>
				</div>

				<div class="mt-8 flex flex-col gap-3 sm:flex-row">
					<a
						href={whatsappUrl()}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex flex-1 items-center justify-center gap-2 rounded-full bg-[#25D366] px-6 py-3 font-semibold text-white transition duration-200 hover:brightness-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-green-400 focus-visible:ring-offset-2"
						aria-label="Contact clinic via WhatsApp"
					>
						WhatsApp Us
					</a>
					<a
						href={`tel:${CLINIC.phone}`}
						class="cta-secondary flex-1 text-center focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2"
					>
						Call Us
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
